# Porta HTTP da API Go
APP_PORT=8080

# Timeout padrão das requisições HTTP (em milissegundos)
REQUEST_TIMEOUT_MS=15000

# String de conexão do PostgreSQL
# Como pegar:
# - Se estiver rodando postgres local padrão: use a URL abaixo
# - Se estiver em docker, ajuste host/porta/usuário/senha/database conforme seu compose
DATABASE_URL=postgres://postgres:postgres@localhost:5432/goledger?sslmode=disable

# Variáveis usadas pelo compose dedicado de PostgreSQL (deploy/docker-compose.postgres.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=goledger
POSTGRES_PORT=5432

# Pool de conexões com o banco (máximo de conexões abertas)
DB_MAX_OPEN_CONNS=10

# Pool de conexões com o banco (mínimo/idle)
DB_MAX_IDLE_CONNS=5

# URL RPC do Besu
# Como pegar:
# - No projeto, o Foundry usa http://127.0.0.1:8545 (SimpleStorage/foundry.toml)
# - Se seu Besu estiver em outro host/porta, altere aqui
BESU_RPC_URL=http://localhost:8545

# ID da chain Besu
# Como pegar:
# - Está em besu/minimal/config.json -> genesis.config.chainId
CHAIN_ID=1337

# Chave privada da conta que envia transações
# Como pegar:
# - Para a devnet local, use a chave pré-financiada do SimpleStorage/.env.example
# - NUNCA use essa chave em rede pública
PRIVATE_KEY=

# Endereço da conta correspondente à PRIVATE_KEY
# Como pegar:
# - Na devnet deste desafio, use o endereço pré-financiado do genesis (besu/minimal/config.json -> alloc)
FROM_ADDRESS=

# Endereço do contrato SimpleStorage já deployado
# Como pegar:
# - Rode na raiz: make devnet-deploy
# - Copie o "SimpleStorage deployed at: 0x..."
CONTRACT_ADDRESS=

# Número de confirmações de bloco para considerar a tx como "confirmed"
CONFIRMATIONS_REQUIRED=2

# Intervalo (segundos) do worker de sync chain -> DB
SYNC_INTERVAL_SECONDS=5

# Quantidade máxima de transações pendentes processadas por ciclo de sync
SYNC_BATCH_SIZE=50
